---
title: Rove - How It Works
---

flowchart LR
    USER["Hosted WebUI / CLI / Channel / Scheduler"]
    USER --> AUTH["Auth + session gate"]
    AUTH --> TASK["Task ingress"]

    subgraph ENGINE["Rove Engine"]
        PROFILE["Daemon profile\ndesktop | headless"]
        CONFIG["TOML config\nprofile presets + overrides"]
        IDENTITY["Identity store\nnode_id + node_name + signing key"]

        PROFILE --> CONFIG
        TASK --> GATEWAY["Gateway\npending_tasks + locks"]
        GATEWAY --> DISPATCH["Dispatch brain\nONNX + heuristics"]
        DISPATCH --> CORE["AgentCore"]
        CORE --> POLICY["Policy engine\nuser + workspace policy files"]
        CONFIG --> POLICY
        CONFIG --> APPROVALS["Approvals\nmode + allowlist rules + pending queue"]

        CORE --> SIMPLE["Linear loop\nsimple tasks"]
        CORE --> COMPLEX["DAG path\nmedium + complex tasks"]
        COMPLEX --> SUB["Subagents\nresearcher / executor / verifier / summariser"]
        COMPLEX --> REMOTE["Signed remote bundles\nexecutor-only or full peers"]

        CORE --> MEMORY["Memory system\nepisodic + graph + project context"]
        SUB --> MEMORY

        CORE --> ROUTER["LLM router"]
        SUB --> ROUTER
        ROUTER --> LOCAL["Local models\nllama.cpp / Ollama"]
        ROUTER --> CLOUD["Cloud models"]

        CORE --> REG["Runtime registry"]
        SUB --> REG
        REG --> SYSTEM["Installable system extensions\nfilesystem / terminal / vision"]
        REG --> NATIVE["Native runtime"]
        REG --> WASM["WASM runtime"]
        REG --> MCP["MCP runtime"]

        REG --> SAFE["FsGuard + CommandExecutor\n+ InjectionDetector + RiskAssessor"]
        CORE --> SECRETS["Secret manager\nvault / keychain / env"]
        CORE --> STORE["SQLite storage\n tasks / events / sessions / approvals"]
        SUB --> STORE
        CORE --> SERVICES["Managed services\nlogging / webui / remote / connector-engine"]
        SERVICES --> SERVICE_INSTALL["Service install\nlogin / boot"]
        IDENTITY --> REMOTE
        REMOTE --> TRANSPORT["Remote transports\nLAN / ZeroTier"]

        PKG["Extension package lifecycle"] --> EXT_INSTALL["Install / enable / disable"]
        EXT_INSTALL --> STORE
    end

    CORE --> DONE["Final answer / streamed events"]

